<script>
document.addEventListener("DOMContentLoaded", function () {

  console.warn("[FRETE] Script iniciado");


  const form2HTML = `
    <div id="shipping-calculator-2" class="shipping-calculator-box">
        
        <div class="inner_ship">
            <p class="field">
                <input type="text" id="address_zip_2" placeholder="Digite seu CEP" maxlength="9" />
            </p>
            <p class="field">
                <input type="button" class="get-rates-2 btn button" value="Calcular frete" />
            </p>
        </div>

        <div id="wrapper-response-2"></div>
    </div>

    <script id="shipping-calculator-response-template-2" type="text/template">
      <p id="shipping-rates-feedback-2" <% if (success) { %> class="success" <% } else { %> class="error" <% } %>>
        <% if (success) { %>
          <% if (rates.length > 1) { %> 
            Existem <%- rates.length %> opções de frete para <%- address %>, a partir de <%= rates[0].price %>.
          <% } else if (rates.length == 1) { %>
            Há uma opção de frete disponível para <%- address %>.
          <% } else { %>
            Não enviamos para este destino.
          <% } %>
        <% } else { %>
          <%- errorFeedback %>
        <% } %>
      </p>
      <ul id="shipping-rates-2">
        <% for (var i=0; i<rates.length; i++) { %>
          <li><%- rates[i].name %> - <%= rates[i].price %></li>
        <% } %>
      </ul> 
    <\/script>
  `;

  let formInjected = false; 


  
  function initShippingCalculator({ zipInputSelector, buttonSelector, wrapperSelector, templateSelector }) {

      const zipInput = document.querySelector(zipInputSelector);
      const calcButton = document.querySelector(buttonSelector);
      const wrapper = document.querySelector(wrapperSelector);

      if (!zipInput || !calcButton || !wrapper) {
        console.warn("[FRETE] Aguardando elementos do formulário...");
        return;
      }

      console.warn("[FRETE] Inicializando formulário 2");

     
      zipInput.addEventListener('input', e => {
          e.target.value = e.target.value
              .replace(/\D/g, '')
              .replace(/(\d{5})(\d)/, '$1-$2')
              .substr(0, 9);
      });

      calcButton.addEventListener('click', async function () {
          const cep = zipInput.value.replace(/\D/g, '');

          if (cep.length !== 8) {
              wrapper.innerHTML = '<p class="error">Por favor, insira um CEP válido.</p>';
              return;
          }

          wrapper.innerHTML = '<p>Buscando endereço e calculando frete...</p>';

          try {

              const viaCep = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
              const data = await viaCep.json();

              if (data.erro) {
                  wrapper.innerHTML = '<p class="error">CEP não encontrado.</p>';
                  return;
              }

              const country = "Brazil";
              const province = data.uf || '';
              const city = data.localidade || '';
              const address = `${city} - ${province}`;

              const prepare = await fetch('/cart/prepare_shipping_rates.json', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                      shipping_address: { zip: cep, country, province }
                  })
              });

              if (!prepare.ok) throw new Error('Erro ao iniciar cálculo.');

              async function getRates() {
                  const res = await fetch(`/cart/async_shipping_rates.json?shipping_address[zip]=${cep}`);
                  const ratesData = await res.json();

                  if (ratesData.status && ratesData.status !== 'ready') {
                      wrapper.innerHTML = '<p>Calculando frete...</p>';
                      return new Promise(resolve => setTimeout(() => resolve(getRates()), 1200));
                  }

                  return ratesData;
              }

              const rates = await getRates();

              if (!rates.shipping_rates?.length) {
                  wrapper.innerHTML = '<p class="error">Nenhuma opção de frete encontrada.</p>';
                  return;
              }

              const context = {
                  success: true,
                  rates: rates.shipping_rates.map(rate => ({
                      name: rate.name,
                      price: Shopify.formatMoney(rate.price, "{{ shop.money_format }}")
                  })),
                  address
              };

              const template = document.querySelector(templateSelector).innerHTML;
              wrapper.innerHTML = _.template(template)(context);

          } catch (err) {
              console.error(err);
              wrapper.innerHTML = '<p class="warn">Aguarde ou clique em Calcular Frete.</p>';
              querySelector('.get-rates-2').click();
              
          }
      });
  }




  
  const observer = new MutationObserver(() => {
      const target = document.querySelector('.wizz-shipping-rate-wrapper');

      if (target && !formInjected) {
          console.warn("[FRETE] Target encontrado. Inserindo formulário 2...");


          document.querySelector('.wizz-shipping-rate-icon').style.display = 'none';
          document.querySelector('.wizz-shipping-rate-title').style.display = 'none';

          const tempDiv = document.createElement("div");
          tempDiv.innerHTML = form2HTML;

          target.parentNode.insertBefore(tempDiv, target);

          formInjected = true;


          
          setTimeout(() => {
              initShippingCalculator({
                  zipInputSelector: '#address_zip_2',
                  buttonSelector: '.get-rates-2',
                  wrapperSelector: '#wrapper-response-2',
                  templateSelector: '#shipping-calculator-response-template-2'
              });
          }, 200);
      }
  });


  
  observer.observe(document.body, { childList: true, subtree: true });

});
</script>




<style>
