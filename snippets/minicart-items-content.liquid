<div class="minicart-items-inner">
  {% if cart.item_count > 0 %}

  <div class="prod">
    <div class="product-cart">
      {% for item in cart.items %}
      <ol class="minicart_item list-unstyled mb-0 px-0" data-line="{{ forloop.index }}">
        <li class="d-flex">

          <div class="thumb_img_cartmini">
            <a href="{{ item.url }}">
              <img loading="lazy" src="{{ item.image | product_img_url: 'small' }}" alt="{{ item.title }}">
            </a>
          </div>

          <div class="product-detail">
            <h3 class="product_name_mini">
              <a href="{{ item.url }}">{{ item.product.title }}</a>
            </h3>
            {% unless item.variant.title == 'Default Title' %}
            <p class="product_variant">{{ item.variant.title }}</p>
            {% endunless %}

            <div class="product_info">
              <div class="product_price">
                <span class="price_sale">{{ item.price | money }}</span>
              </div>

              <div class="product_quanity">
                <minicart-quantity-button>
                  <button type="button" class="qty-btn qty-minus" aria-label="Diminuir quantidade">&#8722;</button>
                  <input
                    type="number"
                    class="qty-input"
                    value="{{ item.quantity }}"
                    min="1"
                    data-line="{{ forloop.index }}"
                    data-variant-id="{{ item.variant_id }}"
                    aria-label="Quantidade do item {{ item.product.title }}"
                  >
                  <button type="button" class="qty-btn qty-plus" aria-label="Aumentar quantidade">&#43;</button>
                </minicart-quantity-button>
              </div>
            </div>
          </div>

          <div class="produc_remove">
            <minicart-remove-button data-line="{{ forloop.index }}">
              <button type="button" aria-label="Remover {{ item.product.title }}">
                <i class="fa fa-trash-o"></i>
              </button>
            </minicart-remove-button>
          </div>

        </li>
      </ol>
      {% endfor %}
    </div>
  </div>

  <div class="sub-total">
    <span class="total-title float-left">{{ 'minicart.general.total_price' | t }}</span>
    <span class="total-price float-right">{{ cart.total_price | money }}</span>
  </div>

  <div class="action-checkout">
    <a href="/cart" class="button-viewcart">
      <span>{{ 'minicart.general.view_cart' | t }}</span>
    </a>
    <a href="/checkout" class="button-checkout">
      <span>{{ 'minicart.general.checkout' | t }}</span>
    </a>
  </div>

  {% else %}

  <div class="list_product_minicart empty">
    <div class="empty-product_minicart">
      <p class="mb-0">{{ 'minicart.general.empty' | t }}</p>
      <a href="/collections/all" class="to-cart">{{ 'minicart.general.shop_now' | t }}</a>
    </div>
  </div>

  {% endif %}
</div>
