{% if settings.active_free_shippings %}
  {% liquid
    assign threshold_cents = settings.free_shipping_threshold | times: 100
    assign progress_pct = cart.total_price | times: 100.0 | divided_by: threshold_cents
    if progress_pct > 100
      assign progress_pct = 100
    endif
    assign remaining = threshold_cents | minus: cart.total_price
    if cart.total_price >= threshold_cents
      assign threshold_reached = true
    else
      assign threshold_reached = false
    endif
  %}

  <style>
    .wizz-rewardbar-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding-bottom: 30px;
    }
    .wizz-rewardbar-title {
      text-align: center;
      color: rgb(97, 97, 97);
      font-size: 13px;
      margin: 0;
    }
    .wizz-rewardbar-title strong {
      font-weight: 650;
    }
    .wizz-rewardbar-inner {
      padding-left: 16px;
      padding-right: 32px;
      width: 100%;
      box-sizing: border-box;
    }
    .wizz-rewardbar-relative {
      position: relative;
      width: 100%;
    }
    .wizz-rewardbar-overlay {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      top: -8px;
    }
    .wizz-rewardbar-icon-wrapper {
      position: absolute;
      top: 12px;
      z-index: 50;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      gap: 3px;
      align-items: center;
      justify-content: center;
    }
    .wizz-rewardbar-icon-box {
      max-height: 36px;
      max-width: 36px;
    }
    .wizz-rewardbar-icon-circle {
      padding: 8px;
      border-radius: 9999px;
      display: inline-block;
      background: rgb(225, 225, 225);
      color: rgb(0, 0, 0);
    }
    .wizz-rewardbar-icon-circle.reached {
      background: rgb(48, 48, 48);
      color: rgb(255, 255, 255);
    }
    .wizz-rewardbar-icon-svg {
      width: 20px;
      height: 20px;
      display: block;
    }
    .wizz-rewardbar-label-wrapper {
      position: absolute;
      top: 42px;
      z-index: 50;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 33.33%;
    }
    .wizz-rewardbar-label-inner {
      display: flex;
      justify-content: center;
      width: 100%;
    }
    .wizz-rewardbar-description {
      line-height: 12px;
      text-align: center;
      text-wrap: wrap;
      width: 75%;
      font-size: 12px;
      color: rgb(48, 48, 48);
      margin: 0;
    }
    .wizz-rewardbar-progressbar-component {
      height: 8px;
      width: 100%;
      background-color: rgb(225, 225, 225);
      border-radius: 10px;
      overflow: hidden;
    }
    .wizz-rewardbar-progress {
      display: block;
      height: 100%;
      background-color: rgb(48, 48, 48);
      transition: width 0.3s ease-in-out;
    }
  </style>

  <div class="wizz-rewardbar-container">
    <p class="wizz-rewardbar-title">
      {% if threshold_reached %}
        {{ settings.shipping_text_concluded }}
      {% else %}
        Você está a <strong>{{ remaining | money }}</strong> de ganhar frete grátis
      {% endif %}
    </p>
    <div class="wizz-rewardbar-inner">
      <div class="wizz-rewardbar-relative">
        <div class="wizz-rewardbar-overlay">
          <div>
            <div
              class="wizz-rewardbar-icon-wrapper"
              style="left: max(0px, calc({{ progress_pct }}% - 18px));"
            >
              <div class="wizz-rewardbar-icon-box">
                <div class="wizz-rewardbar-icon-circle{% if threshold_reached %} reached{% endif %}">
                  <div class="wizz-rewardbar-icon-svg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M4 5.25C4 4.83579 4.33579 4.5 4.75 4.5H11.7414C12.9692 4.5 14.0483 5.31394 14.3856 6.49452L14.8125 7.98862C14.837 8.07452 14.9055 8.1408 14.9922 8.16247L16.6744 8.58303C17.4535 8.77779 18 9.47776 18 10.2808V11.5C18 12.2108 17.5763 12.8226 16.9676 13.0966C16.9889 13.2279 17 13.3627 17 13.5C17 14.8807 15.8807 16 14.5 16C13.1193 16 12 14.8807 12 13.5C12 13.4156 12.0042 13.3322 12.0123 13.25H8.98766C8.99582 13.3322 9 13.4156 9 13.5C9 14.8807 7.88071 16 6.5 16C5.11929 16 4 14.8807 4 13.5C4 13.1444 4.07422 12.8062 4.20802 12.5H3.75C3.33579 12.5 3 12.1642 3 11.75C3 11.3358 3.33579 11 3.75 11H6.25C6.27988 11 6.30935 11.0017 6.33831 11.0051C6.39177 11.0017 6.44568 11 6.5 11C7.19935 11 7.83163 11.2872 8.28536 11.75H12.7146C13.1684 11.2872 13.8007 11 14.5 11C15.1982 11 15.8296 11.2863 16.2832 11.7478C16.4056 11.7316 16.5 11.6268 16.5 11.5V10.2808C16.5 10.1661 16.4219 10.0661 16.3106 10.0382L14.6284 9.61769C14.0217 9.466 13.542 9.00205 13.3702 8.4007L12.9433 6.9066C12.79 6.36997 12.2995 6 11.7414 6H4.75C4.33579 6 4 5.66421 4 5.25ZM6.5 14.5C7.05228 14.5 7.5 14.0523 7.5 13.5C7.5 12.9477 7.05228 12.5 6.5 12.5C5.94772 12.5 5.5 12.9477 5.5 13.5C5.5 14.0523 5.94772 14.5 6.5 14.5ZM14.5 14.5C15.0523 14.5 15.5 14.0523 15.5 13.5C15.5 12.9477 15.0523 12.5 14.5 12.5C13.9477 12.5 13.5 12.9477 13.5 13.5C13.5 14.0523 13.9477 14.5 14.5 14.5Z"></path>
                      <path d="M3.25 8C2.83579 8 2.5 8.33579 2.5 8.75C2.5 9.16421 2.83579 9.5 3.25 9.5H8.25C8.66421 9.5 9 9.16421 9 8.75C9 8.33579 8.66421 8 8.25 8H3.25Z"></path>
                    </svg>
                  </div>
                </div>
              </div>
            </div>
            <div
              class="wizz-rewardbar-label-wrapper"
              style="left: 83.3333%;"
            >
              <div class="wizz-rewardbar-label-inner">
                <p class="wizz-rewardbar-description">Entrega grátis</p>
              </div>
            </div>
          </div>
        </div>
        <div class="wizz-rewardbar-progressbar-component">
          <div
            class="wizz-rewardbar-progress"
            style="width: {{ progress_pct }}%;"
          ></div>
        </div>
      </div>
    </div>
  </div>
{% endif %}
