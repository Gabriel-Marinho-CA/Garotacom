{% comment %}
  sections/minicart-items.liquid
  Section usada exclusivamente pela Shopify Sections Rendering API.
  Quando o JS chama /cart/change.js com sections: ['minicart-items'],
  o Shopify renderiza esta section e retorna o HTML atualizado.
{% endcomment %}

{% include 'minicart-items-content' %}

{% schema %}
{
  "name": "Minicart Items",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Valor mínimo para frete grátis (R$)",
      "default": 200
    }
  ],
  "presets": [
    {
      "name": "Minicart Items",
      "settings": {
        "free_shipping_threshold": 200
      }
    }
  ]
}
{% endschema %}
