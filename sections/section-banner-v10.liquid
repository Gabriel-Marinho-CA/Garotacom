                {% endif %}
                {% if section.settings.btn_banner4 != blank %}
                <a href="{{section.settings.link_banner4}}" class="btn-banner">{{section.settings.btn_banner4}}</a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

