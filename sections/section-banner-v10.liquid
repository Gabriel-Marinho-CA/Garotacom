<div data-section-id="{{ section.id }}" data-section-type="section-banner-v10" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %}">
  <div class="section-banner-v10"> 
    <div class="container container-v2">
      <div class="row mg-75">   
        <div class="col-lg-4 col-12 pd-75 pdl-2"> 
          <div class="item-banner banner1">
            <div class="img-banner">
              <a href="{{section.settings.link_banner1}}" class="d-block">
                {% if section.settings.img_banner1 != blank %}
                <img loading="lazy" width="" height="" data-src="{{ section.settings.img_banner1 | image_url }}" class="lazyload img-fluid w-100" alt="_img_banner_">
                {% else %}
                <img loading="lazy" width="" height="" data-src="https://via.placeholder.com/464x655" class="lazyload img-fluid w-100" alt="_img_banner_">
                {% endif %}
              </a>
            </div>
            <div class="banner-content">
              <div class="info">
                {% if section.settings.sub_title1 != blank %}
                <div class="title-top">{{section.settings.sub_title1}}</div>
                {% endif %}
                {% if section.settings.title_banner1 != blank %}
                <h3 class="title-banner">{{section.settings.title_banner1}}</h3>
                {% endif %}
                {% if section.settings.btn_banner1 != blank %}
                <a href="{{section.settings.link_banner1}}" class="btn-banner">{{section.settings.btn_banner1}}</a>
                {% endif %}
              </div>
            </div>
          </div>
          
        </div>
        <div class="col-lg-8 col-12 pd-75">
          <div class="row mg-75">
            <div class="col-md-6 pd-75">
              <div class="item-banner banner2">
                <div class="img-banner">
                  <a href="{{section.settings.link_banner2}}" class="d-block">
