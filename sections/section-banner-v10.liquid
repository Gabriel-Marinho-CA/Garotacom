                    {% else %}
                    <img loading="lazy" width="" height="" data-src="https://via.placeholder.com/458x317" class="lazyload img-fluid w-100" alt="_img_banner_">
                    {% endif %}
                  </a>
                </div>
                <div class="banner-content">
                  <div class="info">
                    {% if section.settings.sub_title2 != blank %}
                    <div class="title-top">{{section.settings.sub_title2}}</div>
                    {% endif %}
                    {% if section.settings.title_banner2 != blank %}
                    <h3 class="title-banner">{{section.settings.title_banner2}}</h3>
                    {% endif %}
                    {% if section.settings.btn_banner2 != blank %}
                    <a href="{{section.settings.link_banner2}}" class="btn-banner">{{section.settings.btn_banner2}}</a>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-6 pd-75">
              <div class="item-banner banner2">
                <div class="img-banner">
                  <a href="{{section.settings.link_banner3}}" class="d-block">
                    {% if section.settings.img_banner3 != blank %}
                    <img loading="lazy" width="" height="" data-src="{{ section.settings.img_banner3 | image_url }}" class="lazyload img-fluid w-100" alt="_img_banner_">
                    {% else %}
                    <img loading="lazy" width="" height="" data-src="https://via.placeholder.com/458x317" class="lazyload img-fluid w-100" alt="_img_banner_">
                    {% endif %}
                  </a>
                </div>
                <div class="banner-content">
                  <div class="info">
                    {% if section.settings.sub_title3 != blank %}
                    <div class="title-top">{{section.settings.sub_title3}}</div>
                    {% endif %}
                    {% if section.settings.title_banner3 != blank %}
                    <h3 class="title-banner">{{section.settings.title_banner3}}</h3>
                    {% endif %}
                    {% if section.settings.btn_banner3 != blank %}
                    <a href="{{section.settings.link_banner3}}" class="btn-banner">{{section.settings.btn_banner3}}</a>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="item-banner banner3">
            <div class="img-banner">
              <a href="{{section.settings.link_banner4}}" class="d-block">
                {% if section.settings.img_banner4 != blank %}
                <img loading="lazy" width="" height="" data-src="{{ section.settings.img_banner4 | image_url }}" class="lazyload img-fluid w-100" alt="_img_banner_">
                {% else %}
                <img loading="lazy" width="" height="" data-src="https://via.placeholder.com/930x317" class="lazyload img-fluid w-100" alt="_img_banner_">
                {% endif %}
              </a>
            </div>
            <div class="banner-content">
              <div class="info">
                {% if section.settings.sub_title4 != blank %}
                <div class="title-top">{{section.settings.sub_title4}}</div>
                {% endif %}
                {% if section.settings.title_banner4 != blank %}
