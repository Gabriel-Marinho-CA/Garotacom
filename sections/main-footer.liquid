<style>
  .main-footer {
    font-size: 14px;
    line-height: 1.6;
  }

  .main-footer__top {
    padding-left: 20px;
    padding-right: 20px;
  }

  .main-footer__container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .main-footer__grid {
    display: grid;
    grid-template-columns: 1.2fr repeat(auto-fill, minmax(160px, 1fr));
    gap: 40px;
  }

  .main-footer__col--newsletter {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .main-footer__logo img {
    display: block;
    height: auto;
  }

  .main-footer__description {
    margin: 0;
    opacity: 0.8;
  }

  .main-footer__newsletter-form {
    display: flex;
    align-items: stretch;
    border: 1px solid currentColor;
    border-radius: 4px;
    overflow: hidden;
  }

  .main-footer__newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 10px 14px;
    color: inherit;
    font-size: 13px;
    min-width: 0;
  }

  .main-footer__newsletter-input::placeholder {
    color: inherit;
    opacity: 0.6;
  }

  .main-footer__newsletter-btn {
    background: transparent;
    border: none;
    border-left: 1px solid currentColor;
    cursor: pointer;
    padding: 10px 14px;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }

  .main-footer__newsletter-btn:hover {
    opacity: 0.7;
  }

  .main-footer__social {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    gap: 14px;
  }

  .main-footer__social li {
    margin: 0;
  }

  .main-footer__social a {
    font-size: 18px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .main-footer__social a:hover {
    opacity: 0.7;
  }

  .main-footer__col--links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .main-footer__col-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    padding-bottom: 10px;
    position: relative;
  }

  .main-footer__col-title::after {
    content: '';
    display: block;
    width: 30px;
    height: 2px;
    position: absolute;
    bottom: 0;
    left: 0;
  }

  .main-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .main-footer__links a {
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .main-footer__links a:hover {
    opacity: 1;
  }

  .main-footer__bottom {
    padding: 18px 20px;
    margin-top: 0;
  }

  .main-footer__bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .main-footer__copyright {
    margin: 0;
    font-size: 13px;
    opacity: 0.75;
  }

  .main-footer__payment img {
    display: block;
    max-height: 28px;
    width: auto;
    height: auto;
  }

  @media (max-width: 767px) {
    .main-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px 24px;
    }

    .main-footer__col--newsletter {
      grid-column: 1 / -1;
    }

    .main-footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }

  @media (max-width: 479px) {
    .main-footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style>
  .main-footer__top {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  .main-footer__bottom {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    border-top: 1px solid {{ section.settings.text_color }};
  }

  .main-footer__col-title {
    color: {{ section.settings.text_color }};
  }

  .main-footer__col-title::after {
    background-color: {{ section.settings.text_color }};
  }

  @media (max-width: 767px) {
    .main-footer__top {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
</style>

<footer class="main-footer">
  <div class="main-footer__top">
    <div class="main-footer__container">
      <div class="main-footer__grid">

        {%- for block in section.blocks -%}

          {%- if block.type == 'newsletter' -%}
            <div class="main-footer__col main-footer__col--newsletter" {{ block.shopify_attributes }}>

              {%- if block.settings.logo != blank -%}
                <div class="main-footer__logo">
                  <a href="{{ shop.url }}">
                    <img
                      src="{{ block.settings.logo | image_url: width: 400 }}"
                      alt="{{ shop.name }}"
                      width="{{ block.settings.logo_maxwidth }}"
                      loading="lazy"
                      height=""
                    >
                  </a>
                </div>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="main-footer__description">{{ block.settings.description }}</p>
              {%- endif -%}

              <div class="main-footer__newsletter">
                {%- if block.settings.newsletter_form_action != blank -%}
                  {%- assign form_action = block.settings.newsletter_form_action -%}
                {%- else -%}
                  {%- assign form_action = '#' -%}
                {%- endif -%}
                <form class="main-footer__newsletter-form" action="{{ form_action }}" method="post">
                  <input
                    type="email"
                    name="EMAIL"
                    class="main-footer__newsletter-input"
                    placeholder="{{ 'general.newsletter_form.newsletter_email' | t }}"
                    required
                    aria-label="{{ 'general.newsletter_form.newsletter_email' | t }}"
                  >
                  <button class="main-footer__newsletter-btn" type="submit" aria-label="Inscrever">
                    <svg xmlns="http://www.w3.org/2000/svg" height="16" viewBox="0 0 24 24" width="16" fill="currentColor">
                      <path d="m8.75 17.612v4.638c0 .324.208.611.516.713.077.025.156.037.234.037.234 0 .46-.11.604-.306l2.713-3.692z"/>
                      <path d="m23.685.139c-.23-.163-.532-.185-.782-.054l-22.5 11.75c-.266.139-.423.423-.401.722.023.3.222.556.505.653l6.255 2.138 13.321-11.39-10.308 12.419 10.483 3.583c.078.026.16.04.242.04.136 0 .271-.037.39-.109.19-.116.319-.311.352-.53l2.75-18.5c.041-.28-.077-.558-.307-.722z"/>
                    </svg>
                  </button>
                </form>
              </div>

              {%- assign has_social = false -%}
              {%- if block.settings.social_1_icon != blank or block.settings.social_2_icon != blank or block.settings.social_3_icon != blank or block.settings.social_4_icon != blank -%}
                {%- assign has_social = true -%}
              {%- endif -%}

              {%- if has_social -%}
                <ul class="main-footer__social">
                  {%- if block.settings.social_1_icon != blank -%}
                    <li>
                      <a href="{{ block.settings.social_1_url }}" target="_blank" rel="noopener noreferrer">
                        <i class="{{ block.settings.social_1_icon }}"></i>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.social_2_icon != blank -%}
                    <li>
                      <a href="{{ block.settings.social_2_url }}" target="_blank" rel="noopener noreferrer">
                        <i class="{{ block.settings.social_2_icon }}"></i>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.social_3_icon != blank -%}
                    <li>
                      <a href="{{ block.settings.social_3_url }}" target="_blank" rel="noopener noreferrer">
                        <i class="{{ block.settings.social_3_icon }}"></i>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.social_4_icon != blank -%}
                    <li>
                      <a href="{{ block.settings.social_4_url }}" target="_blank" rel="noopener noreferrer">
                        <i class="{{ block.settings.social_4_icon }}"></i>
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              {%- endif -%}

            </div>

          {%- elsif block.type == 'link_list' -%}
            <div class="main-footer__col main-footer__col--links" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h4 class="main-footer__col-title">{{ block.settings.heading }}</h4>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="main-footer__links">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- endif -%}

        {%- endfor -%}

      </div>
    </div>
  </div>

  {%- if section.settings.show_bottom_bar -%}
    <div class="main-footer__bottom">
      <div class="main-footer__bottom-inner">
        {%- if section.settings.copyright_text != blank -%}
          <p class="main-footer__copyright">{{ section.settings.copyright_text }}</p>
        {%- endif -%}
        {%- if section.settings.payment_image != blank -%}
          <div class="main-footer__payment">
            <img
              src="{{ section.settings.payment_image | image_url: width: 400 }}"
              alt="Formas de pagamento"
              loading="lazy"
              width=""
              height=""
            >
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "main-footer-section",
  "blocks": [
    {
      "type": "newsletter",
      "name": "Newsletter & Logo",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "range",
          "id": "logo_maxwidth",
          "label": "Largura máxima do logo",
          "min": 60,
          "max": 300,
          "step": 5,
          "default": 160,
          "unit": "px"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrição",
          "default": "Sua loja de moda favorita."
        },
        {
          "type": "text",
          "id": "newsletter_form_action",
          "label": "URL de ação do formulário (newsletter)"
        },
        {
          "type": "header",
          "content": "Redes Sociais"
        },
        {
          "type": "text",
          "id": "social_1_icon",
          "label": "Ícone 1 (classe Font Awesome)",
          "placeholder": "fa fa-instagram"
        },
        {
          "type": "url",
          "id": "social_1_url",
          "label": "URL 1"
        },
        {
          "type": "text",
          "id": "social_2_icon",
          "label": "Ícone 2 (classe Font Awesome)",
          "placeholder": "fa fa-facebook"
        },
        {
          "type": "url",
          "id": "social_2_url",
          "label": "URL 2"
        },
        {
          "type": "text",
          "id": "social_3_icon",
          "label": "Ícone 3 (classe Font Awesome)",
          "placeholder": "fa fa-tiktok"
        },
        {
          "type": "url",
          "id": "social_3_url",
          "label": "URL 3"
        },
        {
          "type": "text",
          "id": "social_4_icon",
          "label": "Ícone 4 (classe Font Awesome)",
          "placeholder": "fa fa-youtube"
        },
        {
          "type": "url",
          "id": "social_4_url",
          "label": "URL 4"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu de links",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título do menu",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Aparência"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor dos textos e ícones",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Espaçamento — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Espaçamento — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Barra de Copyright"
    },
    {
      "type": "checkbox",
      "id": "show_bottom_bar",
      "label": "Mostrar barra de copyright",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Texto de copyright",
      "default": "© 2025 Garota.com. Todos os direitos reservados."
    },
    {
      "type": "image_picker",
      "id": "payment_image",
      "label": "Imagem de formas de pagamento"
    }
  ],
  "presets": [
    {
      "name": "Footer Principal",
      "blocks": [
        {
          "type": "newsletter"
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Institucional",
            "menu": "footer"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Atendimento",
            "menu": "footer"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Informações",
            "menu": "footer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
